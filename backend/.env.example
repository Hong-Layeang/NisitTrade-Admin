# Server
NODE_ENV=development
PORT=4001

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/nisittrade
DB_POOL_MAX=20
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=60000
DB_POOL_IDLE_MS=10000


# Optional, set only if you have a valid university row id
ADMIN_UNIVERSITY_ID=

# Microsoft auth (if enabled)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_ALLOWED_DOMAINS=

# AWS S3
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# URLs
CLIENT_URL=http://localhost:3001
SHARE_BASE_URL=http://localhost:3001
